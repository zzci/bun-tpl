{
  "name": "@app/monorepo",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Bun monorepo template for OAuth-backed internal workspaces.",
  "homepage": "https://github.com/zzci",
  "repository": {
    "type": "git",
    "url": "https://github.com/zzci/bun-app-tpl.git"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "catalog": {
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "scripts": {
    "dev": "bun run --filter '@app/*' dev",
    "dev:all": "bun scripts/dev-all.ts",
    "dev:dex": "bun scripts/dev-dex.ts",
    "build": "bun run --filter '*' build",
    "lint": "eslint apps/ packages/ scripts/ eslint.config.ts --ext .ts,.tsx",
    "lint:fix": "eslint apps/ packages/ scripts/ eslint.config.ts --ext .ts,.tsx --fix",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "test:e2e": "bun tests/e2e/run.ts",
    "check": "bun run lint && bun run typecheck && bun run test && bun run build && bun run check:i18n && bun run check:env-docs && bun run check:api-docs",
    "check:i18n": "bun scripts/check-i18n.ts",
    "check:env-docs": "bun scripts/gen-env-docs.ts --check",
    "check:api-docs": "bun run --filter @app/api check:api-docs",
    "gen:env-docs": "bun scripts/gen-env-docs.ts",
    "gen:api-docs": "bun run --filter @app/api gen:api-docs",
    "compile": "bun scripts/compile.ts",
    "clean": "bun scripts/clean.ts",
    "clean:all": "bun scripts/clean.ts --all",
    "rebrand": "bun scripts/rebrand.ts",
    "hash-password": "bun scripts/hash-password.ts"
  },
  "devDependencies": {
    "@antfu/eslint-config": "9.0.0",
    "@app/tsconfig": "workspace:*",
    "@eslint-react/eslint-plugin": "5.9.0",
    "@nsio/nsl": "0.1.7",
    "consola": "3.4.2",
    "eslint": "10.5.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "otpauth": "9.5.1",
    "typescript": "catalog:"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "qs": "^6.15.2"
  }
}
