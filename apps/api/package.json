{
  "name": "@app/api",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Hono API on Bun with Drizzle SQLite storage and optional ECIES at-rest encryption.",
  "homepage": "https://github.com/zzci",
  "repository": {
    "type": "git",
    "url": "https://github.com/zzci/bun-app-tpl.git",
    "directory": "apps/api"
  },
  "exports": {
    ".": "./src/dev.ts"
  },
  "scripts": {
    "dev": "nsl run --name \"${APP_NAME:-app}:${BASE_PATH:-}/api\" bun --env-file=../../.env --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --minify",
    "start": "bun dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "bun --env-file=/dev/null test",
    "test:coverage": "bun --env-file=/dev/null test --coverage",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "gen:api-docs": "bun scripts/gen-api-docs.ts",
    "check:api-docs": "bun scripts/gen-api-docs.ts --check"
  },
  "dependencies": {
    "@app/shared": "workspace:*",
    "@libsql/client": "0.17.3",
    "cac": "7.0.0",
    "consola": "3.4.2",
    "cronbake": "0.4.0",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.19",
    "nanoid": "5.1.11",
    "oauth4webapi": "3.8.6",
    "otpauth": "9.5.1",
    "pino": "10.3.1",
    "qrcode": "1.5.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@app/tsconfig": "workspace:*",
    "@types/bun": "1.3.14",
    "@types/qrcode": "1.5.6",
    "drizzle-kit": "0.31.10",
    "typescript": "catalog:"
  }
}
