# .env.example — reference configuration
# Copy to .env and fill in values.
#
# All schema and defaults live in apps/api/src/config.ts. Variables that are
# not set fall back to the default declared there.

# Deployment lifecycle. `development` enables hot dev paths; `production`
# turns on the stricter boot guards (CORS_ORIGIN + ACCESS_URL required,
# example-sentinel refusals); `test` is reserved for the e2e harness.
NODE_ENV=development
# Port the API listens on. The bundled SPA is served from the same port.
PORT=3000
# Bind address. `0.0.0.0` is fine inside containers / behind a reverse
# proxy; restrict to `127.0.0.1` for host-local deployments.
HOST=0.0.0.0

# ─── Branding ───
# Application slug — must match /^[a-z][a-z0-9-]*$/.
# Used as the backup filename prefix, localStorage namespace, and (via
# VITE_APP_NAME) the frontend build.
# APP_NAME=app
# Human-readable display name. Shown in HTML title, TOTP issuer, etc.
# APP_DISPLAY_NAME=App

# URL prefix the app is mounted under. Unset (default) means the app is
# served at root: SPA at "/" and API at "/api". When set, "app", "/app",
# and "/app/" all normalise to "/app" — SPA at "/app/", API at "/app/api".
# Match this with the reverse-proxy mount.
# BASE_PATH=/app

# Public URL used to build OAuth callback URLs.
# REQUIRED in production: forwarded request headers are not trusted there.
# Optional in development: falls back to the inbound request's Host header.
# ACCESS_URL=https://your-domain.com

# Database (relative to ROOT_DIR, or absolute)
DB_PATH=data/db/app.db
# Database-at-rest encryption. Defaults to false for a friction-free dev
# experience. Turn on (DB_ENCRYPTION=true) before any production deploy —
# the setup flow then derives a master keypair and DEK. See
# docs/develop/deployment.md and docs/modules/encryption.md.
# DB_ENCRYPTION=false

# BOOTSTRAP_TOKEN is no longer read from the environment. It is generated
# automatically at every boot and is only published while the system is in
# setup mode (no meta.db yet). Look for it in stderr or in the file
# <data-dir>/bootstrap-token.txt; both are removed once /encryption/init
# succeeds. Token cannot be reused.

# CORS (required in production). Comma-separated list of allowed origins.
# In development, requests through the dev URL router (nsl) are same-origin
# and do not need this set.
# CORS_ORIGIN=https://your-domain.com

# Logging
LOG_LEVEL=info
# Path the pino destination writes to when LOG_TO_STDOUT=false.
# Resolved against the project root when relative. Honours SIGHUP for
# logrotate hand-off (see docs/develop/operations.md).
LOG_FILE=data/logs/app.log
# When true, write JSON log lines to stdout instead of LOG_FILE — preferred
# for container deployments that capture stdout/stderr at the runtime level.
# LOG_TO_STDOUT=false

# When true, honour the rightmost X-Forwarded-For entry (and, as a
# fallback only, X-Real-IP) for client-IP resolution. Default is false:
# forwarding headers are ignored and the connection peer IP is used.
# Only enable behind a sanitising proxy that strips client-supplied
# forwarding headers.
# TRUST_PROXY=false

# Comma-separated CIDR allow-list of immediate proxy peer addresses.
# Forwarding headers are honoured only when the TCP peer matches one of
# these ranges. Empty (default) means "any peer is trusted". Recommended
# in production: set this to the load-balancer / ingress subnet.
# TRUSTED_PROXY_IPS=

# Opt-in flag for the experimental DEK-rotation flow. When false (default)
# the rotation endpoints respond with 501 Not Implemented.
# ENABLE_EXPERIMENTAL_DEK_ROTATION=false

# Cron scheduler gate. When false (default) the Baker timer is NOT
# started and the built-in log-cleanup default is NOT auto-seeded.
# Admins can still create / edit / delete cron jobs through the UI and
# fire manual triggers — they just won't run on schedule until this is
# set to true and the API is restarted. The UI shows an amber
# "scheduler is off" banner while the flag is false. See
# docs/modules/cron.md for the runtime model + shell-action security
# notes before turning this on.
# CRON_ENABLED=false

# Opt-in list (comma-separated) of cron actions whose spec.defaultEnabled
# is false. Each entry is matched against an action's spec.name; listed
# actions are registered and surfaced in the catalog, otherwise they stay
# unregistered (and jobs referencing them fail with UNKNOWN_ACTION).
# Actions shipped with defaultEnabled: true (the common case) are always
# registered regardless of this list.
#
# The built-in `shell` action ships with defaultEnabled: false because
# it runs `sh -c <command>` with the API process's UID and has no sandbox
# — a compromise of one admin account would otherwise pivot to host RCE
# without an operator opt-in. To enable: CRON_ACTIONS_ENABLED=shell
# (add more names comma-separated as you ship custom actions that follow
# the same opt-in pattern).
# CRON_ACTIONS_ENABLED=

# Allow the `http-request` cron action to reach private / loopback /
# link-local destinations (127/8, 10/8, 172.16/12, 192.168/16,
# 169.254/16, ::1, fc00::/7). Default false to block SSRF-style pivots
# into cloud metadata endpoints and internal services from a compromised
# admin session. Enable for legitimate internal pings (e.g. talking to a
# sidecar on localhost).
# HTTP_ACTION_ALLOW_PRIVATE=false

# Per-execution timeout (seconds) for the `http-request` cron action.
# Fetch is aborted via AbortSignal.timeout after this many seconds.
# HTTP_ACTION_TIMEOUT_SECONDS=30

# Per-execution timeout (seconds) for the `shell` cron action. Child
# process is killed via SIGTERM (then SIGKILL after a 5s grace).
# SHELL_ACTION_TIMEOUT_SECONDS=300

# Session lifetime in seconds; seeded into the settings table on first run.
# SESSION_MAX_AGE=86400

# Audit retention in days. 0 = keep forever. The schema default is 0 to
# preserve "never sweep" semantics for the literal value, but production
# deployments should set a finite value so `audit_events` does not grow
# unbounded. 365 (one year) is a reasonable starting point.
AUDIT_RETENTION_DAYS=365

# ─── Attachment upload limits ───
# Per-file cap (bytes). Defaults to 10 MB. Applies to documents and issues.
# MAX_UPLOAD_BYTES=10485760
# Per-resource attachment count cap. Defaults to 20.
# MAX_ATTACHMENTS_PER_RESOURCE=20
# Total disk quota (bytes) across all attachment tables. 0 = unlimited.
# When set, uploads beyond it return 413 QUOTA_EXCEEDED.
# UPLOADS_TOTAL_BYTES=0

# ─── File module ───
# Active storage backend. Built-in: `local`. Downstream projects can
# register additional drivers (e.g. `s3`, `azure-blob`) and switch here.
# FILE_STORAGE_DRIVER=local
# On-disk root for the local driver. Resolved against the project root
# when relative.
# FILE_STORAGE_LOCAL_ROOT=data/uploads/files
# GC mode. `async` (default) — releases only decrement ref_count; a
# background sweeper deletes the blob + the files row once per
# FILE_GC_INTERVAL_SECONDS. `sync` — foreground request also deletes the
# blob (used by tests and local-only deployments).
# FILE_GC_MODE=async
# Sweep interval for the GC. 0 disables the periodic sweep entirely
# (orphans accumulate; admin runs a manual sweep via the API).
# FILE_GC_INTERVAL_SECONDS=3600
# When true and the active driver implements presignDownload, file
# downloads 302 to a short-lived signed URL instead of streaming through
# the API. Permission is enforced at signing time via the consumer hook.
# FILE_PRESIGN_ENABLED=true
# TTL for signed URLs in seconds. Short by design: a leaked URL stays
# valid only briefly; re-issuing requires the consumer permission hook
# to pass again.
# FILE_PRESIGN_TTL_SECONDS=300

# ─── Service tokens (non-interactive automation) ───
# Bearer credentials for tooling that cannot use a session cookie. Each
# scope is independent so a leaked metrics scraper credential cannot also
# exfiltrate the database. Each value must be ≥ 32 chars; generate with:
#   openssl rand -hex 32
# Bearer token authorising scrapes of /api/metrics (read-only, Prometheus).
# SERVICE_TOKEN_METRICS=   # GET /api/metrics
# Bearer token authorising backup export over POST /api/backup/export-via-token.
# Keep distinct from SERVICE_TOKEN_METRICS so a leaked scraper credential
# cannot also exfiltrate the database.
# SERVICE_TOKEN_BACKUP=    # POST /api/backup/export-via-token

# Minimum seconds between successful service-token backup exports.
# Throttles a leaked backup token from being turned into a DOS lever
# (repeated full-DB reads amplify WAL pressure). 0 disables the gate.
# BACKUP_EXPORT_MIN_INTERVAL_SECONDS=300

# Path to a single-use file containing the master password for
# unattended unlock. Mode must be 0600. The API reads the file at
# boot, POSTs to /api/encryption/unlock on loopback, then deletes
# the file. See docs/develop/operations.md § Sealed-file unlock.
# MASTER_PASSWORD_FILE=

# ─── Auth provider and first admin bootstrap ───
# OAuth/OIDC is read from environment variables at runtime, not from the
# settings database. Use OAUTH_ISSUER for discovery or provide all endpoints.
#
# Client id registered at the IdP for this deployment.
# OAUTH_CLIENT_ID=
# Client secret. Keep out of public configuration management; pull from a
# secrets store and inject as env var at runtime.
# OAUTH_CLIENT_SECRET=
# Authorization Code with PKCE. Leave true unless the IdP forbids PKCE.
# OAUTH_PKCE=true
# OIDC issuer URL — when set the API hits `<issuer>/.well-known/openid-
# configuration` and auto-fills the four endpoints below. Production
# discovery hits are cached next to the DB for boot-time fallback.
# OAUTH_ISSUER=
# Explicit endpoint overrides — only needed when the IdP does not expose
# OIDC discovery. Each must be a full HTTPS URL.
# Authorization endpoint the browser is redirected to to start login.
# OAUTH_AUTHORIZE_URL=
# Token endpoint the server posts to to exchange the code for tokens.
# OAUTH_TOKEN_URL=
# Userinfo endpoint the server calls with the access token to load
# claims used to upsert the user row.
# OAUTH_USERINFO_URL=
# RP-Initiated Logout endpoint. When set the `/account/auth/logout` flow
# redirects the browser here after revoking the local session so the IdP
# also tears down its SSO cookie.
# OIDC_LOGOUT_URL=
#
# Used only when the users table is empty. The first matching login becomes
# admin; existing users are never promoted by this value.
# DEFAULT_ADMIN=

# ─── Single-user mode (OAuth bypass) ───
# Enable to authenticate against a username + password kept in the env
# instead of an OIDC provider. Registration and password change are not
# exposed; rotate by editing these variables and restarting the API.
# When SINGLE_USER_MODE=true the OAuth /login route is disabled and the
# SPA renders a local form.
# SINGLE_USER_MODE=false

# Username for the single-user account. Compared case-insensitively.
# SINGLE_USER_USERNAME=

# Path to a file containing the password hash. Recommended over the inline
# variable below because Bun's dotenv parser expands `$VAR` (even inside
# `'...'`), so an inline hash needs every `$` backslash-escaped.
# Accepted hash formats (auto-detected by prefix): bcrypt ($2a/2b/2y$...),
# argon2id ($argon2id$...), PBKDF2-SHA256 (pbkdf2-sha256$...).
# The file may contain a raw hash, OR a single htpasswd line — `user:hash`
# is recognised and the leading `user:` is stripped.
# Easiest one-liner:
#   mkdir -p .secret && htpasswd -B -n -b admin 'my-password' > .secret/admin.hash
# SINGLE_USER_PASSWORD_HASH_FILE=.secret/admin.hash

# Inline alternative when a file is not practical. Every `$` in the hash
# must be backslash-escaped, e.g.
#   SINGLE_USER_PASSWORD_HASH=\$2y\$05\$... (bcrypt from htpasswd)
#   SINGLE_USER_PASSWORD_HASH=pbkdf2-sha256\$600000\$<salt>\$<hash>
# Generators (any one):
#   htpasswd -B -n -b admin 'my-password' | cut -d: -f2-   # bcrypt
#   bun run hash-password                                  # PBKDF2-SHA256
# SINGLE_USER_PASSWORD_HASH=

# Optional display name shown in the UI (defaults to the username).
# SINGLE_USER_NAME=

# Optional email used for audit / display (defaults to <username>@local).
# SINGLE_USER_EMAIL=

# ─── Bundled dex IdP (local dev) ───
# Uncomment the block below to point the app at the dex IdP started by
# `bun run dev:dex`. The dex script reads the same OAUTH_CLIENT_ID /
# OAUTH_CLIENT_SECRET / ACCESS_URL values to generate its static-client
# config, so the two sides stay in sync as long as you edit them together.
#
# Default (HTTP via nsl wildcard *.localhost):
# OAUTH_ISSUER=http://dex-app.localhost:3355
# OAUTH_CLIENT_ID=app
# OAUTH_CLIENT_SECRET=app-secret
# OAUTH_PKCE=true
# DEFAULT_ADMIN=admin@example.com
# ACCESS_URL=http://app.localhost:3355
#
# HTTPS variant (if your nsl proxy exports a wildcard TLS domain, e.g.
# `*.a.wd.ds.cc`). Use this when testing OIDC flows that depend on
# HTTPS-only browser behaviours (SameSite=None cookies, etc.):
# OAUTH_ISSUER=https://dex-app.a.wd.ds.cc
# ACCESS_URL=https://app.a.wd.ds.cc
