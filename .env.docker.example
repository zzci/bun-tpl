# Runtime environment for the production docker-compose (lode) deploy.
# Copy to `.env.docker` and fill in real values. This is the container's
# env (loaded via `env_file`); lode passes it through to the launched app.
# See `.env.example` for the full list of supported variables.

# Public URL the app is served at — must match the Traefik Host rule.
APP_URL=https://app.example.com
CORS_ORIGIN=https://app.example.com

# OIDC provider. CLIENT_SECRET is optional when OAUTH_PKCE=true (default).
OAUTH_ISSUER=
OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=

# Bootstrap admin (email or username) granted admin on first login.
DEFAULT_ADMIN=

# Encrypt the SQLite database at rest.
DB_ENCRYPTION=false

# Data location: app data anchors at `${LODE_DIR}/data` = /srv/lode/data
# automatically (a subdir of the lode volume, kept separate from lode's own
# state.json/versions/), so no DB_PATH / FILE_STORAGE_LOCAL_ROOT is needed.
# Set DATA_DIR to relocate it (e.g. a separate volume).
# DATA_DIR=/srv/lode/data
