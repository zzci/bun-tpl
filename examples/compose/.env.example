# Reference env for examples/compose. LOCAL DEV ONLY.
# Copy to .env in this directory before `docker compose up`.
#
# ┌─ PRODUCTION DEPLOYERS — READ THIS ────────────────────────────────────┐
# │ Before exposing this stack to anything beyond your local laptop, ROTATE │
# │ every secret below AND the matching value in dex.yaml. The app refuses  │
# │ to start in NODE_ENV=production while OAUTH_CLIENT_SECRET still holds   │
# │ the example value `app-secret`.                                         │
# └─────────────────────────────────────────────────────────────────────────┘

APP_NAME=app
APP_DISPLAY_NAME=App
BASE_PATH=/app
APP_URL=http://localhost
CORS_ORIGIN=http://localhost

# This stack runs Caddy in front of the API and forwards the real
# client IP via X-Forwarded-For (see Caddyfile). Honour it so audit
# rows / rate-limit buckets key on the actual visitor IP rather than
# Caddy's container address. Required whenever you put a sanitising
# proxy in front; defaults to false in apps/api/src/config.ts because
# trusting forwarding headers behind no proxy would let any client
# spoof their IP.
TRUST_PROXY=true

# Must match dex.yaml staticClients[0].id / .secret.
OAUTH_CLIENT_ID=app
OAUTH_CLIENT_SECRET=app-secret
# Issuer must match what dex publishes in its discovery document
# (see /dex/.well-known/openid-configuration). The app talks to dex
# server-to-server inside the docker network, so use the service hostname.
# If your browser also needs to hit dex (e.g. for end-session redirects),
# add an /etc/hosts entry like `127.0.0.1 dex` and keep this URL the same.
OAUTH_ISSUER=http://dex:5556/dex

# BOOTSTRAP_TOKEN is no longer read from the environment. It is generated
# automatically at every boot and only published while the system is in
# setup mode (no meta.db yet). After `docker compose up`, find it with:
#   docker compose logs app | grep BOOTSTRAP_TOKEN
# or read it from <data volume>/bootstrap-token.txt. Both go away once
# /encryption/init succeeds; the token cannot be reused.

# First matching login becomes admin. Matches the seeded dex user.
DEFAULT_ADMIN=admin@example.com

# Database-at-rest encryption.
# The API's own default (apps/api/src/config.ts) is `false` — friction-free
# local dev. The bundled `compose.yml` overrides that with
# `DB_ENCRYPTION=${DB_ENCRYPTION:-true}`, so leaving this commented out
# still encrypts production deploys behind the reference stack. Set
# explicitly to `false` here if you really want plaintext on disk.
DB_ENCRYPTION=true

# Optional bearers for non-interactive automation. Each scope is
# independent. ≥ 32 chars; generate with: openssl rand -hex 32
# SERVICE_TOKEN_METRICS= # gates GET /api/metrics
# SERVICE_TOKEN_BACKUP=  # gates POST /api/backup/export-via-token
